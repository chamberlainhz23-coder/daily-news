# OpenAI-compatible model provider
OPENAI_API_KEY=your-api-key
OPENAI_MODEL=deepseek-v4-flash
OPENAI_BASE_URL=https://api.deepseek.com

# Push channel
WECOM_WEBHOOK=
SERVERCHAN_SENDKEY=

# Local testing
DRY_RUN=true

# Output volume
MAX_NEWS_ITEMS=12
MAX_CANDIDATES=80
MAX_PER_FEED=20
LLM_MAX_TOKENS=4200
BRIEFING_DETAIL_LEVEL=deep

# Optional custom RSS feeds, one per line
NEWS_FEEDS=
