# OpenAI 或兼容 OpenAI Chat Completions 的大模型接口
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# 企业微信群机器人 Webhook，优先使用
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key

# Server酱 SendKey，企业微信不方便时使用
SERVERCHAN_SENDKEY=

# 本地测试时设为 true，只打印简报，不推送
DRY_RUN=true

# 每天最多输出新闻数量
MAX_NEWS_ITEMS=10

# 给大模型的候选新闻数量
MAX_CANDIDATES=30

# 可选：自定义 RSS 源。每行一个。
# 如果不配置，会使用 main.py 内置新闻源。
# NEWS_FEEDS 支持在 GitHub Secrets 中配置多行文本。
NEWS_FEEDS=
