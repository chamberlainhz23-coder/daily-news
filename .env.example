# OpenAI-compatible model provider
OPENAI_API_KEY=your-api-key
OPENAI_MODEL=deepseek-v4-flash
OPENAI_BASE_URL=https://api.deepseek.com

# Push channel
WECOM_WEBHOOK=
SERVERCHAN_SENDKEY=

# Local testing
DRY_RUN=true

# Output volume
MAX_NEWS_ITEMS=20
MAX_CANDIDATES=140
MAX_PER_FEED=30
LLM_MAX_TOKENS=5200
BRIEFING_DETAIL_LEVEL=brief

# Optional custom RSS feeds, one per line
NEWS_FEEDS=
